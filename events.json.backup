  "google_form_field_mapping": {
    "note": "This maps Google Form field names to JSON fields for automated pipeline",
    "fields": {
      "College Name": "college_name",
      "Event Title": "title",
      "Event Type": "type",
      "Event Date (Start)": "schedule.start_date",
      "Event Date (End)": "schedule.end_date",
      "Start Time": "schedule.start_time",
      "End Time": "schedule.end_time",
      "Venue / Location": "venue.name",
      "Is this an online event?": "venue.is_online",
      "Online Link (if any)": "venue.online_link",
      "Short Description": "details.description",
      "Open to public?": "details.is_open_to_public",
      "Open to other colleges?": "details.open_to_other_colleges",
      "Entry Fee (NPR, write 0 if free)": "details.entry_fee",
      "Registration Required?": "details.registration_required",
      "Registration Link": "details.registration_link",
      "Registration Deadline": "details.registration_deadline",
      "Contact Person Name": "details.contact_person",
      "Contact Phone": "details.contact_phone",
      "Contact Email": "details.contact_email",
      "Source URL (Facebook post / website link)": "source.source_url",
      "Poster Image URL (Google Drive link)": "media.poster_url",
      "Tags (comma separated)": "tags",
      "Submitted By": "source.submitted_by"
    }
  },

  "pipeline_note": {
    "step_1": "Google Form submissions saved to Google Sheets",
    "step_2": "Apps Script or Make.com reads new rows every hour",
    "step_3": "Auto-generates event_id (evt_XXX), slug, and created_at timestamp",
    "step_4": "POST to your backend API endpoint: POST /api/events",
    "step_5": "Backend validates required fields and sets verified=false (pending admin review)",
    "step_6": "Admin approves/rejects from dashboard, sets verified=true",
    "step_7": "Approved events appear on Event Board within 1 hour",
    "expiry_logic": "Events auto-expire (is_active=false) after end_date passes (cron job daily at midnight NPT)"
  }
}
